generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inventory {
  id          String      @id @default(cuid())
  userId      String
  name        String
  description String?
  imageUrl    String?
  version     Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  fieldMetas  FieldMeta[]
  idTemplate  IdTemplate?
  items       Item[]
  posts       Post[]

  @@index([userId])
  @@index([userId, name])
}

enum FieldKey {
  text1
  text2
  text3
  multiline1
  multiline2
  multiline3
  num1
  num2
  num3
  bool1
  bool2
  bool3
  link1
  link2
  link3
}

// Added this Enum to fix the "Type string is not assignable to FieldType" error
enum FieldType {
  TEXT
  NUMBER
  BOOLEAN
  LINK
  MULTILINE
}

model FieldMeta {
  id          String    @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  fieldKey    FieldKey
  fieldType   FieldType // Updated from String to FieldType
  title       String
  description String?
  showInTable Boolean   @default(true)
  sortOrder   Int       @default(0)

  @@unique([inventoryId, fieldKey])
  @@index([inventoryId])
}

model IdTemplate {
  id          String    @id @default(cuid())
  inventoryId String    @unique
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  elements    Json      @default("[]")
  sequenceVal Int       @default(0)
}

model Item {
  id          String    @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  customId    String?
  version     Int       @default(0)
  text1       String?
  text2       String?
  text3       String?
  multiline1  String?
  multiline2  String?
  multiline3  String?
  num1        Decimal?  @db.Decimal(18, 4)
  num2        Decimal?  @db.Decimal(18, 4)
  num3        Decimal?  @db.Decimal(18, 4)
  bool1       Boolean?
  bool2       Boolean?
  bool3       Boolean?
  link1       String?
  link2       String?
  link3       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([inventoryId, customId])
  @@index([inventoryId])
}

model Post {
  id          String    @id @default(cuid())
  inventoryId String
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  userId      String
  userName    String
  userAvatar  String?
  content     String
  createdAt   DateTime  @default(now())

  @@index([inventoryId, createdAt])
}